        {
          "probability": 0.6,
          "result_text": "前两天拷贝文件，一切都看起来很正常。直到课堂展示当天，你发现U盘里的文件全部损坏，被扣平时分，追悔莫及。",
          "stat_changes": {
            "health_storage": -20,
            "mental_state": -30,
            "health_system": -5
          }
        },
        {
          "probability": 0.4,
          "result_text": "你刚把U盘插上电脑，系统就提示「此驱动器存在问题」。你试着格式化，结果U盘彻底变砖。",
          "stat_changes": {
            "health_hardware": -10,
            "mental_state": -15,
            "health_system": -10
          }
        }
      ]
    },
    {
      "option_id": "opt_ask_clinic",
      "text": "先问问电脑诊所的同学靠谱吗",
